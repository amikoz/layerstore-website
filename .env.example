# ====================================
# LayerStore Environment Configuration
# ====================================

# Copy this file to .env and configure your values

# ------------------------------------
# Resend Email Configuration
# ------------------------------------
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Email sender configuration
EMAIL_FROM=noreply@layerstore.eu
EMAIL_FROM_NAME=LayerStore
EMAIL_REPLY_TO=info@layerstore.eu

# Default recipient for order notifications
EMAIL_DEFAULT_RECIPIENT=info@layerstore.eu

# Sandbox mode - set to true for testing without sending real emails
EMAIL_SANDBOX=false

# Log file path for email service
EMAIL_LOG_FILE=/tmp/resend_email.log

# ------------------------------------
# Site Configuration
# ------------------------------------
SITE_URL=https://layerstore.eu

# ------------------------------------
# Stripe Configuration
# ------------------------------------
# Get your keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ------------------------------------
# Orders API Configuration
# ------------------------------------
# API key for order management (change in production!)
ORDERS_API_KEY=change-me-in-production

# ------------------------------------
# Development / Testing
# ------------------------------------
# APP_ENV=production
# DEBUG=false
